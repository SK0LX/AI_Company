# Default provider powering the agents (each agent can override this in the
# admin panel — provider + model + API key + base URL — so one agent can run on
# Claude while another runs on an OpenRouter free model or any custom endpoint):
#   "openrouter"        (free models, OpenAI-compatible) — default
#   "google"            (Gemini, free tier)
#   "anthropic"         (Claude API; Opus 4.7/4.8 are most capable)
#   "openai_compatible" (any OpenAI-compatible endpoint — set base_url per agent)
LLM_PROVIDER=openrouter

# --- OpenRouter (free models) ---
# Get a key at https://openrouter.ai/keys
# Note: free models have a shared daily request cap on your account (it is
# raised substantially once you add a small amount of credit). A multi-agent
# run makes several calls, so you can still hit the cap on a free account.
OPENROUTER_API_KEY=

# --- Google Gemini (only if LLM_PROVIDER=google) ---
# Get a key at https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# --- Anthropic Claude (only if LLM_PROVIDER=anthropic) ---
ANTHROPIC_API_KEY=

# Model used by the specialists. Leave empty to use the provider default
# (openrouter -> openai/gpt-oss-120b:free,
#  google -> gemini-2.5-flash-lite, anthropic -> claude-sonnet-4-6).
# Other reliable free options: z-ai/glm-4.5-air:free, google/gemma-4-31b-it:free,
# qwen/qwen3-coder:free (when not rate-limited upstream).
AGENT_MODEL=openai/gpt-oss-120b:free

# Optionally give the CEO a stronger model than the specialists.
# Leave empty to use the provider's CEO default (openrouter ->
# nvidia/nemotron-3-super-120b-a12b:free), else AGENT_MODEL for everyone.
CEO_MODEL=nvidia/nemotron-3-super-120b-a12b:free

# --- Execution engine (LLM by API key  vs  Claude Code CLI / bash console) ---
# How a task is actually run:
#   "llm"        — (default) every agent runs on its LLM provider above via the
#                  API key. Classic path: the LangGraph CEO plans and delegates.
#   "claude_cli" — the whole team request is handed to the local Claude Code CLI
#                  (`claude -p`): Claude itself plans, delegates to your team
#                  personas, writes files and runs shell commands in the project
#                  folder, streaming each step into the same live ticker. This is
#                  the "bash console" engine. It needs the `claude` CLI installed
#                  (the Docker image already bundles it) and authenticated — run
#                  `claude login` once, or set ANTHROPIC_API_KEY. You can also set
#                  the engine PER AGENT in the admin panel (it overrides this).
TEAM_ENGINE=llm
# Model passed to `claude -p --model` (empty = the CLI default). Accepts a full id
# like claude-opus-4-8 / claude-sonnet-4-6 or a short alias (opus/sonnet).
CLAUDE_MODEL=
# FAST model for the cheap, every-message calls: the lead router (chit-chat vs
# delegate), casual replies, and the relay hand-off decision. The heavy work
# (specialists building/analysing) keeps CLAUDE_MODEL. "haiku" = snappy "хоп и
# ответил"; on the subscription it still costs $0.
CLAUDE_FAST_MODEL=haiku
# Relay (эстафета) cap: max agent hops in one chain (lead → agent → agent …) before
# it is forced to stop, so a chain can't loop or run forever.
CLAUDE_RELAY_MAX_HOPS=6
# Distributed group mode: on every message EACH agent independently decides to work,
# reply, or stay silent. They run concurrently; this caps how many `claude`
# subprocesses run AT ONCE (each is a ~200-300MB node process) so a small VPS doesn't
# OOM. 3 is safe for ~1.5GB; raise it on a bigger box for more true parallelism.
GROUP_MAX_PARALLEL=3
# `claude` prefers ANTHROPIC_API_KEY over a logged-in subscription when the env
# var is set. Set true to drop the key from the CLI so it uses `claude login`
# (your subscription) instead — usually the cheaper path.
CLAUDE_USE_SUBSCRIPTION=false
# Tool-approval mode for `claude -p` (acceptEdits auto-approves file edits). The
# engine runs unattended — keep this only on a trusted, sandboxed workspace.
CLAUDE_PERMISSION_MODE=acceptEdits
# Hard cap (seconds) on one `claude -p` task before it is killed.
CLAUDE_TIMEOUT=1200

# --- Claude-engine permissions (Claude-Code style) ---
# Every tool a Claude-engine agent uses is sorted into ONE of 4 categories:
#   read 📖 (read/browse files) · edit ✏️ (write files) · exec ⚙️ (run bash/git/
#   build) · net 🌐 (web/download). Per category it is either auto-allowed or sent
#   to you as an approval you resolve in the WEB DASHBOARD (the agent waits).
# CLAUDE_AUTO_APPROVE=true is the global AUTO mode — everything runs, no prompts.
# When AUTO is off, the per-category flags decide: by default the agent reads and
# edits files freely, but RUNNING COMMANDS and reaching the NETWORK ask for your
# OK in the dashboard. Set the exec/net ones true to let it clone/build/fetch
# without asking. (An unresolved approval is denied after COMMAND_APPROVAL_TIMEOUT.)
CLAUDE_AUTO_APPROVE=false
CLAUDE_AUTO_READ=true
CLAUDE_AUTO_EDIT=true
CLAUDE_AUTO_EXEC=false
CLAUDE_AUTO_NET=false

# --- Telegram ---
# Create a bot via @BotFather and paste the token here.
TELEGRAM_BOT_TOKEN=

# --- Behavior ---
MAX_TOKENS=4096
TEMPERATURE=0.3

# Stream the agents' internal chatter (CEO delegations + each specialist's
# reply) into the chat, not just the final answer. Set false for final-only.
SHOW_TEAM_CHATTER=true

# The team works internally in English. When true, the mirrored chatter is
# translated into Russian for you (one extra model call per specialist reply).
# Set false to save quota — chatter then shows the English originals.
TRANSLATE_CHATTER=true

# OpenRouter free tier shares ONE daily request cap across all :free models.
# It's 50/day under $10 balance and 1000/day once you add $10 (the models stay
# free — the credit just unlocks the higher cap). The bot estimates how many
# requests are left and warns you when only FREE_DAILY_WARN_AT remain.
# If you add $10 of credit, set FREE_DAILY_LIMIT=1000 here.
FREE_DAILY_LIMIT=50
FREE_DAILY_WARN_AT=10

# --- v2 platform ---
# Secret used to encrypt per-agent Telegram tokens at rest (admin panel). Leave
# empty to auto-generate a stable key in data/secret.key. Any string works.
APP_SECRET=

# Admin panel + bots run as ONE process (python main.py). Bind to localhost for
# local use; when you expose it (Docker/Caddy) set API_TOKEN below.
ADMIN_HOST=127.0.0.1
ADMIN_PORT=8100

# Operator token for the dashboard's state-changing API (create/delete agents,
# budgets, routines, approve shell/self-modify, …). REQUIRED before exposing the
# panel on a network: when set, every mutating /api request must send it as
# `X-Api-Token: <token>` (the web UI auto-attaches it; open it once as
# .../?token=<token> to save it, or it comes from the Telegram Mini App login).
# Leave empty ONLY for purely-local use — then mutations are allowed from
# 127.0.0.1 and rejected for anyone over the network.
API_TOKEN=

# Delegation-with-consent (stage 4): before a specialist runs, ask it (one extra
# model call) whether it accepts the hand-off; on decline the CEO re-routes. OFF
# by default — it spends a call per delegation, which matters on the free daily
# cap. Task/event tracking and the help flow run regardless (they cost no LLM).
ENABLE_NEGOTIATION=false

# Proactive posting (stage 7): agents post short updates to the team chat on
# events (task done, help needed, declined). OFF by default. Needs TEAM_CHAT_ID
# (the group/chat the team bot posts into) and the per-agent `proactive`
# permission (set in the admin panel). Messages are templated (no LLM cost);
# guardrails (cooldown, per-agent rate limit, dedup, mute) always apply.
ENABLE_PROACTIVE=false
TEAM_CHAT_ID=0
PROACTIVE_MIN_INTERVAL=30
PROACTIVE_MAX_PER_WINDOW=5
PROACTIVE_WINDOW=300

# Telegram Mini App: public HTTPS URL where the dashboard is reachable, so the
# bots show a "Дашборд" menu button that opens it inside Telegram. Telegram only
# opens HTTPS (not localhost) — use a tunnel in dev (e.g. `cloudflared tunnel
# --url http://127.0.0.1:8100` or ngrok) and paste the https URL here, or deploy.
# Leave empty to disable. WEBAPP_ALLOWED_USER_IDS restricts who may open it
# (comma-separated Telegram user IDs; empty = any user with a valid signature).
WEBAPP_URL=
WEBAPP_ALLOWED_USER_IDS=

# Where conversation memory is stored (SQLite, persists across restarts).
DB_PATH=data/memory.sqlite

# Shared workspace where the team saves real project files (one subfolder per
# project). The developer/frontend file tools are sandboxed to this directory.
WORKSPACE_DIR=/Users/daniilbutakov/test

# Long-term team knowledge base, stored as plain Markdown — open the folder
# directly as an Obsidian vault. When enabled, the CEO reads relevant notes
# before starting a request and writes a short project card when a task
# finishes, so the team "remembers" past projects and decisions across runs.
ENABLE_WIKI=true
WIKI_DIR=~/ObsidianAITeam

# Let the Developer agent RUN Python to verify its code. This executes
# model-generated code on your machine — keep OFF unless you trust the chat.
ENABLE_CODE_EXECUTION=false
CODE_EXEC_TIMEOUT=15

# Let agents run REAL shell commands (npm install, pytest, docker compose, ...)
# in the project folder so they can actually install/build/test. Commands run ON
# YOUR MACHINE, so this is OFF by default and EVERY command must be approved by
# you via a Telegram button before it runs. Only the project folder is the cwd,
# but this is not a real sandbox — enable only on a machine you trust.
# SHELL_TIMEOUT caps one command; COMMAND_APPROVAL_TIMEOUT is how long the bot
# waits for your approval tap before skipping the command.
ENABLE_SHELL_EXECUTION=false
SHELL_TIMEOUT=300
COMMAND_APPROVAL_TIMEOUT=600
