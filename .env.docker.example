# Copy to .env and fill in. Used by docker-compose (env_file).

# --- Telegram (required) ---
TELEGRAM_BOT_TOKEN=123456:your-team-bot-token

# --- LLM provider + keys ---
# llm_provider: openrouter | anthropic | google | openai_compatible
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-...
# OPENROUTER_API_KEY=sk-or-...
# GOOGLE_API_KEY=...

# --- Encryption key for per-agent secrets at rest (any string; keep it stable) ---
APP_SECRET=change-me-to-a-long-random-string

# --- Durability: FULL fsyncs every commit so the board/outbox/ledger survive a
#     host/power crash (recommended for a 24/7 deploy). Use NORMAL for speed. ---
DB_SYNCHRONOUS=FULL

# --- Operator token for the mutating dashboard API (REQUIRED when exposed) ---
# In Docker the app is reachable through Caddy, i.e. over the network — so set
# this. Every POST/PATCH/DELETE /api call must carry `X-Api-Token: <token>`
# (the web UI attaches it automatically; open .../?token=<token> once to save it).
# Without it, those calls are rejected for non-local clients.
API_TOKEN=change-me-to-another-long-random-string

# --- Chats ---
# TEAM_CHAT_ID=-1001234567890        # where the team posts (proactive)
# TASK_CHANNEL_ID=-1009876543210     # Задачник: task lifecycle feed

# --- Feature switches (all OFF by default) ---
# ENABLE_SHELL_EXECUTION=true        # agents run real commands (sandboxed in-container)
# ENABLE_BUDGET=true                 # enforce budget hard-stops
# ENABLE_ROUTINES=true               # scheduled jobs
# ENABLE_AUTOWORK=true               # agents pull+do unclaimed board tasks 24/7
# ENABLE_SELF_MODIFY=true            # maintainer edits the bot's own code (+ shell)
# ENABLE_PROACTIVE=true              # agents post to team chat on events

# --- Public dashboard (optional, for Telegram Mini App over HTTPS via Caddy) ---
# WEBAPP_URL=https://ai.example.com
